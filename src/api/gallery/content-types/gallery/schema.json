{
  "kind": "collectionType",
  "collectionName": "galleries",
  "info": {
    "singularName": "gallery",
    "pluralName": "galleries",
    "displayName": "Gallery"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Workshop",
        "Hackathon",
        "Startup Event",
        "Training",
        "Seminar",
        "Conference",
        "MoU Signing",
        "Investor Meet",
        "Competition",
        "Campus Activity",
        "Other"
      ]
    },
    "eventdate": {
      "type": "date"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "featured": {
      "type": "boolean"
    },
    "order": {
      "type": "integer"
    }
  }
}
